# ====================================================================
# GOOGLE OAUTH CONFIGURATION FOR GOOGLE SHEETS INTEGRATION
# ====================================================================
# This file contains the environment variables required for per-user
# Google Sheets integration via OAuth 2.0
#
# Follow these steps to set up:
#
# 1. Go to Google Cloud Console: https://console.cloud.google.com
# 2. Create a new project or select an existing one
# 3. Enable the Google Sheets API:
#    - Go to "APIs & Services" > "Library"
#    - Search for "Google Sheets API"
#    - Click "Enable"
# 4. Create OAuth 2.0 credentials:
#    - Go to "APIs & Services" > "Credentials"
#    - Click "Create Credentials" > "OAuth client ID"
#    - Choose "Web application"
#    - Add authorized redirect URIs:
#      * http://localhost:3000/api/oauth/google/callback (for development)
#      * https://yourdomain.com/api/oauth/google/callback (for production)
#    - Copy the Client ID and Client Secret
# 5. Configure the OAuth consent screen:
#    - Go to "APIs & Services" > "OAuth consent screen"
#    - Add your app name, support email, and authorized domains
#    - Add scopes:
#      * https://www.googleapis.com/auth/spreadsheets
#      * https://www.googleapis.com/auth/userinfo.email
#      * https://www.googleapis.com/auth/userinfo.profile
# 6. Generate encryption key:
#    - Run: node -e "console.log(require('crypto').randomBytes(32).toString('base64').substring(0, 32))"
#    - Or use: openssl rand -base64 32 | cut -c1-32
# ====================================================================

# Google OAuth Client ID (from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# Google OAuth Client Secret (from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret-here

# Google OAuth Redirect URI (must match the one in Google Cloud Console)
# For development: http://localhost:3000/api/oauth/google/callback
# For production: https://yourdomain.com/api/oauth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# Encryption key for storing OAuth tokens securely (MUST be exactly 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64').substring(0, 32))"
OAUTH_ENCRYPTION_KEY=your-32-character-encryption-key

# Your app's public URL (used for redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ====================================================================
# LEGACY SERVICE ACCOUNT (OPTIONAL - FOR BACKWARD COMPATIBILITY)
# ====================================================================
# If you want to support the old service account method alongside OAuth,
# keep these variables. Otherwise, you can remove them.
#
# Service Account Email (from Google Cloud Console > Service Accounts)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Service Account Private Key (from Service Account JSON file)
# Replace \n with actual newlines or use the JSON file directly
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ====================================================================
# IMPORTANT SECURITY NOTES
# ====================================================================
# 1. NEVER commit this file with real values to version control
# 2. The encryption key MUST be exactly 32 characters
# 3. Keep your OAuth credentials secure
# 4. Use different credentials for development and production
# 5. Regularly rotate your credentials
# 6. Monitor OAuth token usage in Google Cloud Console
# ====================================================================
